# --- Retailer selection ---
# "bonpreu" (default) or "ocado". This single var switches domain, login,
# locale and currency. Override individual fields below if needed.
RETAILER=bonpreu

# --- Optional per-field overrides (normally NOT needed) ---
# BASE_URL=https://www.compraonline.bonpreuesclat.cat
# LOGIN_URL=https://www.compraonline.bonpreuesclat.cat/login
# LOCALE=ca-ES
# TIMEZONE_ID=Europe/Madrid
# CURRENCY=€

# --- Storage ---
# Leave GCS_BUCKET UNSET to keep everything local (recommended for a
# Home Assistant / self-hosted setup). Setting it makes the server upload
# your session cookies to Google Cloud Storage instead.
# GCS_BUCKET=
